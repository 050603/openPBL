# ============================================================================
# OpenPBL environment variables
# ============================================================================
# Copy this file to `.env.local` and fill in real values. NEVER commit the
# populated file. The runtime reads variables from `process.env`; in Docker,
# `docker-compose.yml` mounts `.env.local` via `env_file:` and interpolates a
# few `${VARIABLE}` references at compose-up time (POSTGRES_PASSWORD below).
# ----------------------------------------------------------------------------

# LLM configuration for course generation.
# When unset, the UI shows a placeholder and allows "Use sample content" to
# continue.
OPENPBL_LLM_ENDPOINT=
OPENPBL_LLM_API_KEY=
OPENPBL_LLM_MODEL=

# Teacher-side classroom generation uses four concurrent scene workers by
# default. Set 1 for serial generation, or tune within the supported 1-5 range.
PARALLEL_SCENE_CONCURRENCY=4

# TTS uses conservative provider metadata defaults (normally 2 segments, up to
# 4). Override globally or per provider, for example:
# TTS_CONCURRENCY=2
# TTS_OPENAI_TTS_CONCURRENCY=4

# ============================================================================
# Production deployment (Stage 1+: PostgreSQL + Prisma)
# ============================================================================

# PostgreSQL connection string. Required for production.
# When unset, the server falls back to a local JSON file store (demo mode)
# and logs a warning. Run `pnpm db:migrate-from-json` after configuring to
# migrate existing data.
# In docker-compose, the app service sets this automatically to
# `postgresql://openpbl:${POSTGRES_PASSWORD}@postgres:5432/openpbl` — only set
# DATABASE_URL here if you're running the app outside compose.
# Example: postgresql://openpbl:password@localhost:5432/openpbl
DATABASE_URL=

# Public base URL of the deployment. Used to build absolute URLs in course
# generation callbacks. Required in production — the legacy `localhost:3000`
# fallback has been removed.
# Example: https://openpbl.example.com
PUBLIC_BASE_URL=

# Secret used to sign JWT auth cookies (Stage 2). Must be a long random string.
# Generate with: `openssl rand -base64 48`
JWT_SECRET=

# Redis is used for cross-instance realtime invalidation delivery.
# Example: redis://localhost:6379
REDIS_URL=

# Realtime server. Browser clients use same-origin /ws by default; set the
# public URL only for development without the supplied Nginx proxy.
ENABLE_WEBSOCKET=true
WEBSOCKET_PORT=3001
NEXT_PUBLIC_WEBSOCKET_URL=

# ============================================================================
# Docker Compose only — NOT read by the app directly.
# `docker-compose.yml` interpolates these into the postgres service env.
# ============================================================================
# Password for the `openpbl` Postgres role. Generate with:
#   `openssl rand -base64 32`
# This value is interpolated into POSTGRES_PASSWORD on the postgres service
# and into DATABASE_URL on the app service at `docker compose up` time.
POSTGRES_PASSWORD=
